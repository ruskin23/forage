# Forage environment configuration.
# Copy this file to `.env` and fill in your values:  cp .env.example .env

# OpenRouter API key — powers all AI agents (summary, profile, scoring).
# Create one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Postgres connection string.
# The default matches the docker-compose service (host port 5433).
DATABASE_URL=postgres://forage:forage@localhost:5433/forage
